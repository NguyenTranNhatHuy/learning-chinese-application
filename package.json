{
  "name": "learning-chinese",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack website học tiếng Trung mỗi ngày với React, Express và MongoDB.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "seed": "npm run seed --workspace server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001799",
    "lodash": "^4.18.1"
  }
}
